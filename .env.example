# Public app config (safe to expose to the browser)
NEXT_PUBLIC_APP_URL=https://your-app.example.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-anon-key

# Server-only secret. NEVER prefix with NEXT_PUBLIC_.
# Required for Google Calendar OAuth (stores tokens in user_google_integrations).
# Get it from Supabase Dashboard → Project Settings → API → service_role key.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Calendar OAuth (server-only secrets)
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
# Must exactly match an authorized redirect URI in the Google Cloud console.
GOOGLE_REDIRECT_URI=https://your-app.example.com/api/google-calendar/callback
